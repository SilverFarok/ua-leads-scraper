APP_NAME=ua-business-leads-mvp
LOG_LEVEL=INFO

INPUT_CSV=data/input.csv
DATABASE_PATH=data/leads.sqlite3
OUTPUT_DIR=output
LOG_DIR=logs

REQUEST_TIMEOUT_SEC=20
REQUEST_RETRIES=3
REQUEST_DELAY_SEC=1.5
MAX_SEARCH_RESULTS_PER_QUERY=30
MAX_SITE_PAGES_PER_COMPANY=3
ENRICHMENT_WORKERS=5
TARGET_MOBILE_LEADS=5000
BLOCKED_DOMAINS=

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

UA_MOBILE_PREFIXES=39,50,63,66,67,68,73,91,92,93,94,95,96,97,98,99
CONTACT_PATH_KEYWORDS=контакт,контакти,contact,contacts,about,about-us,про-нас,pro-nas,зв'язок,zviazok
